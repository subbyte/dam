{
  "name": "prototype",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800",
  "scripts": {
    "dev": "pnpm --filter agent-runtime dev",
    "start": "pnpm --filter agent-runtime start",
    "ui": "pnpm --filter platform-ui dev",
    "api-server": "pnpm --filter api-server dev",
    "typecheck": "pnpm -r --parallel run typecheck",
    "docker:platform-base:build": "docker build -f packages/platform-base/Dockerfile -t platform-base .",
    "docker:platform-base:start": "docker rm -f platform-base 2>/dev/null; docker run --name platform-base -p 8080:8080 platform-base",
    "docker:claude-code:build": "pnpm docker:platform-base:build && docker build -t platform-claude-code packages/agents/claude-code",
    "docker:claude-code:start": "docker rm -f platform-claude-code 2>/dev/null; docker run --name platform-claude-code -p 3000:3000 platform-claude-code"
  },
  "pnpm": {
    "packageExtensions": {
      "@hookform/resolvers": {
        "peerDependencies": {
          "zod": "*"
        },
        "peerDependenciesMeta": {
          "zod": {
            "optional": true
          }
        }
      }
    },
    "overrides": {
      "@anthropic-ai/sdk@<0.91.1": "0.91.1",
      "brace-expansion@5.0.5": "5.0.6",
      "esbuild@<0.25.0": "0.25.12",
      "protobufjs@<7.5.8": "7.5.8",
      "qs@<6.15.2": "6.15.2",
      "serialize-javascript@<7.0.5": "7.0.5",
      "ws@8.20.0": "8.20.1"
    },
    "onlyBuiltDependencies": [
      "@google/genai",
      "esbuild",
      "grpc-tools",
      "koffi",
      "msgpackr-extract",
      "protobufjs",
      "sharp"
    ]
  },
  "devDependencies": {
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.1.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.3"
  }
}
